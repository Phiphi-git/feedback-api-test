# Configuration exemple - À adapter selon vos besoins

# Port de l'API
PORT=3000

# Base de données Cloud SQL (optionnel si utilisant CSV)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=votre_mot_de_passe
DB_NAME=feedback_db

# API personnalisée (remplacer vos données)
FEEDBACK_API_URL=https://votre-api.com/api
FEEDBACK_API_KEY=votre_clé_api

# Service ML (optionnel)
SENTIMENT_API_URL=http://localhost:8080
ML_MODEL_PATH=./sentiment_model.pkl
